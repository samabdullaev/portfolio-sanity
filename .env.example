# Sanity Studio + seeder configuration.
# Copy this file to .env and fill in your values.

# Sanity project ID + dataset name. Public-readable (embedded in image
# URLs the live site serves) but env-driven so the same code can target
# multiple datasets / multiple Sanity projects (e.g. for forks).
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=

# Sanity API token with write permissions, used by the seeders to create
# and patch documents. Create one at https://www.sanity.io/manage,
# Project → API → Add API token, role "Editor" or "Administrator".
# Never commit a real token.
SANITY_TOKEN=
